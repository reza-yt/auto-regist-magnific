# ===========================================
# MAGNIFIC AUTO REGISTRATION - CLI CONFIG
# ===========================================

# --- Proxy ---
# Options: file, single, scrape (auto scrape free proxies)
PROXY_MODE=scrape
# If using single proxy:
PROXY_URL=socks5://user:pass@127.0.0.1:1080

# --- Temp Mail Provider ---
# Options: mail_tm (free, recommended), guerrilla (free), kopeechka (paid)
TEMP_MAIL_PROVIDER=mail_tm
# If using kopeechka.store (paid, most reliable):
KOPEECHKA_API_KEY=

# --- Registration Settings ---
BATCH_COUNT=5
REGISTRATION_DELAY=15000
MAX_RETRIES=3

# --- Browser ---
HEADLESS=true

# --- Output ---
OUTPUT_FILE=api_keys.txt
LOG_LEVEL=info
