# ===========================================
# MAGNIFIC AUTO REGISTRATION - CONFIGURATION
# ===========================================

# --- Proxy Configuration ---
# Proxy format: protocol://user:pass@host:port
# Supported: http, https, socks4, socks5
# You can also use proxy list file (see proxies.txt)
PROXY_MODE=file
# Options: file, single, rotating_service
# If using single proxy:
PROXY_URL=socks5://user:pass@127.0.0.1:1080
# If using rotating proxy service:
ROTATING_PROXY_URL=http://user:pass@rotating-proxy.example.com:8080

# --- Temp Mail Provider ---
# Options: mail_tm, mail_td, guerrilla, kopeechka
TEMP_MAIL_PROVIDER=mail_tm
# If using kopeechka.store (paid, most reliable):
KOPEECHKA_API_KEY=your_kopeechka_api_key_here

# --- Registration Settings ---
# Number of accounts to register in batch mode
BATCH_COUNT=5
# Delay between registrations (ms) - randomized ±30%
REGISTRATION_DELAY=15000
# Max retries per account
MAX_RETRIES=3

# --- Browser Settings ---
HEADLESS=true
# Browser viewport randomization
MIN_WIDTH=1280
MAX_WIDTH=1920
MIN_HEIGHT=720
MAX_HEIGHT=1080

# --- Output ---
OUTPUT_FILE=api_keys.txt
LOG_LEVEL=info

# --- Anti-Detect Settings ---
# WebGL vendor spoofing
WEBGL_VENDOR=Google Inc.
# Canvas noise injection
CANVAS_NOISE=true
# Audio context spoofing
AUDIO_SPOOF=true
