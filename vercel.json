{
  "functions": {
    "app/api/register/route.js": {
      "maxDuration": 300,
      "memory": 3009
    },
    "app/api/proxy-scrape/route.js": {
      "maxDuration": 60,
      "memory": 512
    },
    "app/api/status/route.js": {
      "maxDuration": 10,
      "memory": 256
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache" }
      ]
    }
  ]
}
