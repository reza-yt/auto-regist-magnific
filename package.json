{
  "name": "magnific-auto-regist",
  "version": "3.0.0",
  "description": "CLI tool - Auto registration magnific.ai with temp mail, proxy rotation, anti-detect browser, and API key extraction",
  "type": "module",
  "main": "src/index.js",
  "bin": {
    "magnific-regist": "./src/index.js"
  },
  "scripts": {
    "start": "node src/index.js",
    "register": "node src/index.js --mode=register",
    "batch": "node src/index.js --mode=batch --count=5",
    "scrape-proxy": "node src/proxy/scraper.js"
  },
  "dependencies": {
    "playwright": "^1.45.0",
    "axios": "^1.7.2",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "https-proxy-agent": "^7.0.5",
    "socks-proxy-agent": "^8.0.3",
    "uuid": "^10.0.0",
    "winston": "^3.13.0",
    "p-queue": "^8.0.1",
    "ora": "^8.0.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": ["magnific", "auto-register", "temp-mail", "proxy", "anti-detect", "cli"],
  "license": "MIT"
}
